    /**
     * Returns the largest value in a that is less than or equal to
     * the given key. This method throws an IllegalArgumentException if
     * a is null or has zero length, or if there is no qualifying
     * value. Note that key does not have to be an actual value in a.
     * The array a is not changed by this method.
     */
   public static int floor(int[] a, int key) {
     // Throw if a is null or empty
      if (a == null || a.length == 0) {
         throw new IllegalArgumentException(
            "array must not be null or empty");
      }
      
      // scan the array and find a value that meets the criteria
      // Does this value meet the criteria? Yes or No?
      boolean foundFloor = false;
      int highestFloor = 0;
      
      // loop through each value in the array
      for (int i = 0; i < a.length; i++) {
         // Criteria Check
         if (a[i] <= key) {
            // Have we found a qualifying floor yet?
            // If not do this
            if (!foundFloor) {
               highestFloor = a[i];
               foundFloor = true;
            }
            // If we have do this instead
            else if (a[i] > highestFloor) {
               highestFloor = a[i];
            }
         }
      }
      // Throw if no qualifying value found
      if (!foundFloor) {
         throw new IllegalArgumentException(
            "no qualifying value.");
      }
      return highestFloor;
   }
   
   public static int removeDuplicates(int[] nums) {
      int duplicateValues = 0;
      int indexSlider = 0;
      
      for (int i = 1; i < nums.length; i++) {
         if (nums[i] == nums[i - 1]) {
            nums[indexSlider] = nums[i];
            indexSlider++;
            duplicateValues++;
         }
      }
      return duplicateValues;
     
   }
   
   public static void main(String[] args) {
      int[] nums = {1, 1, 2, 3, 4, 4};
      
      int check = removeDuplicates(nums);
      System.out.println(check);
      System.out.println(Arrays.toString(nums));
   }

